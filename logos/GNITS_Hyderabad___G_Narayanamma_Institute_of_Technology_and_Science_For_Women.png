<style id="wp-custom-css">
.program .elementor-widget-wrap {
 background:#ececec;
	padding: 30px!important;
  z-index: 10;
  display: inline-block;
  text-decoration: none;


}

  .program .elementor-widget-wrap:after {
   background:linear-gradient(140deg, rgba(253,200,48,1) 35%, rgba(243,171,53,1) 100%);
    content: '';    
    display: block;
    height: 100%;
    position: absolute;
    top:0 ; 
    left: 0;
    opacity: 0;
    width: 100%;
    z-index: -10;
    transition: opacity 0.3s;
  }



.program .elementor-widget-wrap:hover:after {
  opacity: 1;   
}

.program .elementor-widget-wrap:hover {
  opacity: 1;   
}

