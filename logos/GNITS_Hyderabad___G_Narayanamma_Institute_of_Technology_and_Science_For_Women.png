				<div class="elementor-widget-container">
					<!-- ============================================================
     FEE PAYMENT BUTTON – Compact version
     Unique ID: #gnits-fee-btn
     Colors: bg #003e3d · text #f2b526
     Font: Urbanist 800 · border-radius: 20px · no border
     Reduced size · compact text
     ============================================================ -->

<style>
  /* ----- import Urbanist font (800 weight) ----- */
  @import url('https://fonts.googleapis.com/css2?family=Urbanist:wght@800&display=swap');

  /* ----- wrapper – centers the button ----- */
  #gnits-fee-btn-wrapper {
    display: block;
    width: 100%;
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
    font-family: 'Urbanist', sans-serif;
  }

  /* ----- the button – compact, no border, 20px radius ----- */
  #gnits-fee-btn {
    display: inline-block;
    background-color: #003e3d;
    border: none;
    border-radius: 20px;
    padding: 0.7rem 1.8rem;          /* reduced padding */
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(242, 181, 38, 0.12);
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.2s ease;
    animation: gnits-shadowGlow 1.1s ease-in-out infinite alternate;
    text-align: center;
    line-height: 1.3;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 14px;                 /* smaller base */
    letter-spacing: 1px;
    color: #f2b526;
  }

  /* hover / active – subtle feedback */
  #gnits-fee-btn:hover {
    transform: scale(1.03);
    box-shadow: 0 0 30px rgba(242, 181, 38, 0.2), 0 6px 20px rgba(0, 0, 0, 0.4);
  }

  #gnits-fee-btn:active {
    transform: scale(0.96);
  }

  /* ----- blinking text – smaller, compact ----- */
  #gnits-fee-btn .gnits-blink-text {
    display: inline-block;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 1.4rem;               /* reduced from 2.8rem */
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #f2b526;
    background: transparent;
    text-shadow:
      0 0 6px rgba(242, 181, 38, 0.4),
      0 0 14px rgba(242, 181, 38, 0.25),
      0 0 24px rgba(242, 181, 38, 0.15);
    animation: gnits-blinkHard 0.9s ease-in-out infinite alternate;
    padding: 0.05rem 0.1rem;
    position: relative;
  }

  /* subtle glow behind text – scaled down */
  #gnits-fee-btn .gnits-blink-text::before {
    content: '';
    position: absolute;
    inset: -6px -12px;
    background: radial-gradient(circle at 30% 40%, rgba(242, 181, 38, 0.15), transparent 70%);
    filter: blur(10px);
    z-index: -1;
    border-radius: 10px;
    animation: gnits-glowPulse 0.9s ease-in-out infinite alternate;
  }

  /* ----- link icon (→) – smaller ----- */
  #gnits-fee-btn .gnits-link-icon {
    display: inline-block;
    font-family: 'Urbanist', sans-serif;
    font-weight: 800;
    font-size: 1.3rem;               /* reduced */
    line-height: 1;
    color: #f2b526;
    opacity: 0.85;
    vertical-align: middle;
    margin: 0 0.15rem;
    filter: drop-shadow(0 0 4px rgba(242, 181, 38, 0.25));
    transition: transform 0.2s ease;
  }

  /* arrow moves slightly on hover */
  #gnits-fee-btn:hover .gnits-link-icon {
    transform: translateX(3px);
  }

  /* ----- label flex container – compact gap ----- */
  #gnits-fee-btn .gnits-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;                     /* reduced gap */
    flex-wrap: wrap;
  }

  /* ----- animations (scoped) ----- */
  @keyframes gnits-blinkHard {
    0% {
      opacity: 0.7;
      text-shadow: 0 0 6px rgba(242, 181, 38, 0.3), 0 0 12px rgba(242, 181, 38, 0.15);
      transform: scale(0.98);
      filter: brightness(0.95);
    }
    30% {
      opacity: 1;
      text-shadow: 0 0 10px #f2b526, 0 0 20px #f2b526, 0 0 40px rgba(242, 181, 38, 0.4);
      transform: scale(1.02);
      filter: brightness(1.2);
    }
    70% {
      opacity: 1;
      text-shadow: 0 0 12px #f2b526, 0 0 28px #f2b526, 0 0 50px rgba(242, 181, 38, 0.5);
      transform: scale(1.04);
      filter: brightness(1.4);
    }
    100% {
      opacity: 0.95;
      text-shadow: 0 0 16px #f2b526, 0 0 36px #f2b526, 0 0 60px rgba(242, 181, 38, 0.45);
      transform: scale(1);
      filter: brightness(1.6);
    }
  }

  @keyframes gnits-glowPulse {
    0% { opacity: 0.2; transform: scale(0.95); }
    100% { opacity: 0.6; transform: scale(1.2); }
  }

  @keyframes gnits-shadowGlow {
    0% {
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(242, 181, 38, 0.08);
    }
    100% {
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4), 0 0 24px rgba(242, 181, 38, 0.2);
    }
  }

  /* ----- responsive – even smaller on mobile ----- */
  @media (max-width: 550px) {
    #gnits-fee-btn {
      padding: 0.5rem 1.2rem;
      font-size: 12px;
    }
    #gnits-fee-btn .gnits-blink-text {
      font-size: 1.1rem;
      letter-spacing: 1px;
    }
    #gnits-fee-btn .gnits-link-icon {
      font-size: 1rem;
    }
    #gnits-fee-btn .gnits-label {
      gap: 0.3rem;
    }
  }

  @media (max-width: 400px) {
    #gnits-fee-btn .gnits-blink-text {
      font-size: 0.95rem;
      letter-spacing: 0.5px;
    }
    #gnits-fee-btn .gnits-link-icon {
      font-size: 0.9rem;
    }
    #gnits-fee-btn {
      padding: 0.4rem 0.9rem;
    }
  }

  /* ----- no extra text, no hint, pure button ----- */
</style>

<!-- ===== BUTTON HTML – compact ===== -->
<div id="gnits-fee-btn-wrapper">
  <a href="https://rapid.grayquest.com/gnit-master" target="_blank" rel="noopener noreferrer nofollow" id="gnits-fee-btn">
    <span class="gnits-label">
      <span class="gnits-blink-text">FEE PAYMENT</span>
      <span class="gnits-link-icon">→</span>
    </span>
  </a>
</div>				</div>
