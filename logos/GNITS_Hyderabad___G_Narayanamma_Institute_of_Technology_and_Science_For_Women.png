	   display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.home .nameDesignation .elementor-image-box-description{
		   display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;

}

.testimonial {
	margin:10px;
}

.program.value:hover{
	transform:scale(1.12);
	z-index:12;
	transition:scale 1s ease-in-out;
}

.program.value:hover p{
	color:black!important;
}




